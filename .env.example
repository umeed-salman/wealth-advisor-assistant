# .env

# Wealth Advisor Assistant Configuration
# Copy this file to .env and modify the values as needed.

# Application settings
WEALTH_ADVISOR_APP_NAME="Wealth Advisor Assistant"
WEALTH_ADVISOR_APP_VERSION="0.1.0"
WEALTH_ADVISOR_LOG_LEVEL="INFO"

# LLM settings
WEALTH_ADVISOR_LLM_PROVIDER="ollama"
WEALTH_ADVISOR_LLM_MODEL="llama3.2"
WEALTH_ADVISOR_LLM_API_BASE="http://localhost:11434"
WEALTH_ADVISOR_LLM_API_KEY="ollama"
WEALTH_ADVISOR_LLM_TEMPERATURE="0.2"
WEALTH_ADVISOR_LLM_TIMEOUT_SECONDS="45"

# Directory settings
WEALTH_ADVISOR_INPUT_DIR="input"
WEALTH_ADVISOR_OUTPUT_DIR="output"
WEALTH_ADVISOR_DATA_DIR="data"
WEALTH_ADVISOR_MEMORY_DIR="output/memory"

# Orchestrator settings
WEALTH_ADVISOR_APPROVAL_MODE="manual"
WEALTH_ADVISOR_APPROVAL_TIMEOUT_SECONDS="300"

# Tool settings
WEALTH_ADVISOR_CRM_FAILURE_RATE="0.0"
